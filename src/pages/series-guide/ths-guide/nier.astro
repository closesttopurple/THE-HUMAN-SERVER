---
import TextLayout from "@/layouts/TextLayout.astro"
import '@/styles/text.css'
---

<TextLayout>
</TextLayout>
<title>More Information</title>
<style>
        @media screen and (orientation: portrait)
{
img{
    width: 80%;
    height: 80%;
    }
    .title{
        text-align:left;
    }
    .para{
    text-indent: 0em;
}
}

@media screen and (orientation: landscape)
{
img{
    width: 375px;
    height: 250px;
}
}
#cen{
    text-align: center;
}
.para{
    text-indent: 0em;
}
  @media  (prefers-color-scheme: dark){
    body::before {
  content: "";
  position: fixed;
  width: 100%;
  height: 100%;
  z-index: -1; 
  pointer-events: none; 
  background-image: linear-gradient(to top, #1d1d1d, #1d1d1d, #474747, #474747);
  background-size: 100% 3px;
}
  }
    @media  (prefers-color-scheme: light){
    body::before {
  content: "";
  position: fixed;
  width: 100%;
  height: 100%;
  z-index: -1; 
  pointer-events: none; 
  background-image: linear-gradient(to top, #e8e8e8, #e8e8e8, #d2d2d2, #d2d2d2);
  background-size: 100% 3px;
}
  }</style>
