<title>Short Stories</title>
<style>
  .para{
  display: inline-block;
  height:auto;
  text-size-adjust: auto;
  margin-bottom: 1%;
    margin-top: 0.6cm;
  margin-left: 8%;
  margin-right: 8%;
  letter-spacing: 0.17rem;
  font-size: 115%;

}
div{
  text-align: center;
}
@media screen and (orientation: portrait) {
  .line{
  margin-top: 6.5%;
}
.para u a{
  margin-top: 5%;
  margin-bottom: 30px;
}
.para{
    font-size: 135%;
}
}  @media  (prefers-color-scheme: dark){
    body::before {
  content: "";
  position: fixed;
  width: 100%;
  height: 100%;
  z-index: -1; 
  pointer-events: none; 
  background-image: linear-gradient(to top, #1d1d1d, #1d1d1d, #474747, #474747);
  background-size: 100% 3px;
}
  }
    @media  (prefers-color-scheme: light){
    body::before {
  content: "";
  position: fixed;
  width: 100%;
  height: 100%;
  z-index: -1; 
  pointer-events: none; 
  background-image: linear-gradient(to top, #e8e8e8, #e8e8e8, #d2d2d2, #d2d2d2);
  background-size: 100% 3px;
}
  }
</style>
