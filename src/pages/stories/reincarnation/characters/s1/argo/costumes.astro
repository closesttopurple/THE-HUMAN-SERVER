<title>Argo's Costumes</title><style>    body {
  background-color: $bgColor;
  background-size: 8px 8px;
  background-image: linear-gradient(90deg, transparent, transparent 3px, rgba(0,0,0,.07) 4px),
    linear-gradient(transparent, transparent 3px, rgba(0,0,0,.07) 4px);
  color: $color;
  font-weight: 300;
  margin: 0;
  min-height: 100vh;
  box-shadow: inset 0 0 150px rgba($color, .4), inset 0 0 150px rgba($color, .3);
  
  display: flex;
  min-height: 100vh;
  flex-direction: column;
}
@media (prefers-color-scheme: light)
{
    body {
  background-color: $bgColor;
  background-size: 8px 8px;
  background-image: linear-gradient(90deg, transparent, transparent 3px, rgba(181, 181, 181, 0.07) 4px),
    linear-gradient(transparent, transparent 3px, rgba(228, 228, 228, 0.07) 4px);
  color: $color;
  font-weight: 300;
  margin: 0;
  min-height: 100vh;
  box-shadow: inset 0 0 150px rgba($color, .4), inset 0 0 150px rgba($color, .3);
  
  display: flex;
  min-height: 100vh;
  flex-direction: column;
}
