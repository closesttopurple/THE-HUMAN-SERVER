<style>

  @media screen and (orientation: landscape)
{
  .sub-title{
  margin-top: 0.6cm;
  font-size: 150%;
  font-family: "Life-Regular";
  margin-bottom: 0.1cm;
  margin-left: 8%;
  margin-right: 8%;
  font-weight: 500;
letter-spacing: 2.5px;
}
.title{
  font-size: 200%;

}

}
.img-special{
        width: 362.75px;
    height: 512px;
          border: thick solid rgb(25, 25, 25);
    background-color: rgb(70, 70, 70);
}
  @media screen and (orientation: portrait)
{
  .sub-title{
  margin-top: 1cm;
  font-size: 130%;
  font-family: "Life-Regular";
  font-weight: 400;
  margin-bottom: 0.1cm;
}
.title{
    font-size: 180%;
}

}
.title{
    margin: 0%;
}
.over-text-media{
width: 60%;
height: 40%;
margin: 0 auto;
  text-align: justify;
padding: 1rem;}
 @media  (prefers-color-scheme: dark){

  .text-bg{
  background-color:rgb(70, 70, 70);
  padding: 0.7rem;
}
}
  @media  (prefers-color-scheme: light){

  .text-bg{
  background-color:rgb(253, 253, 253);
  padding: 0.7rem;
}

}

</style>
