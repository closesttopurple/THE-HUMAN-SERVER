<style>

  @media screen and (orientation: landscape)
{
  .sub-title{
  margin-top: 0.6cm;
  font-size: 150%;
  font-family: "Life-Regular";
  margin-bottom: 0.1cm;
  margin-left: 8%;
  margin-right: 8%;
  font-weight: 500;
letter-spacing: 2.5px;
}
.title{
  font-size: 200%;

}

}
#img-front{
        width: 40%;
    height: 40%;
          border: thick solid rgb(25, 25, 25);
    background-color: rgb(70, 70, 70);
}
  @media screen and (orientation: portrait)
{
  .sub-title{
  margin-top: 1cm; 
  font-size: 130%;
  font-family: "Life-Regular";
  font-weight: 400;
  margin-bottom: 0.1cm;
}
.title{
    font-size: 180%;
}

}
.title{
    margin: 0%;
}
.over-text-media{
width: 80%;
height: 60%;
margin: 0 auto;
  text-align: justify;
padding: 1rem;}
 @media  (prefers-color-scheme: dark){

  .text-bg{
  background-color:rgb(70, 70, 70);
  padding: 0.7rem;
}
}
  @media  (prefers-color-scheme: light){

  .text-bg{
  background-color:rgb(253, 253, 253);
  padding: 0.7rem;
}

}
#img-small{
          width:  875.25px;
    height: 1235.5px;
}
@media screen and (orientation: portrait){
    #img-small{
          width:  80%;
    height: 80%;
}
}.title{
  color:rgb(85, 153, 235);
}
</style>
<title>The Materials</title>
<img class="img-special" id="img-small" src="https://ik.imagekit.io/closesttopurple/og/drakengard-1-the-materials.avif">
<div class="over-text-media">
<div class="text-bg">
<p class="title">The Materials</p>
<p class="sub-title">Drag-on Dragoon</p>
</div>
</div>

<div class="over-text-media">
<div class="text-bg">
<p class="title">Type</p>
<p class="sub-title">Artbook</p>
<p class="title">Description</p>
<p class="sub-title">Mostly an artbook for Drag-on Dragoon, it also contains character stories, details about the weapons, and an interview.</p>
<p class="title">Where to find on THE HUMAN SERVER?</p>
<p class="sub-title">Access the reader service <u><a href="https://reader.thehumanserver.org/read.html?title=dod-the-materials&volume=1&page=1">here.</a></u></p>
</div>
</div>

