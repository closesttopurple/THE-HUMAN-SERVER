---
import BaseLayout from "@/layouts/BaseLayout.astro"
import '@/styles/text.css'
import TextLayout from "@/layouts/TextLayout.astro"
---

<TextLayout>
</TextLayout><style>    body {
  background-color: $bgColor;
  background-size: 6px 6px;
  background-image: linear-gradient(90deg, transparent, transparent 3px, rgba(0,0,0,.07) 4px),
    linear-gradient(transparent, transparent 3px, rgba(0,0,0,.07) 4px);
  color: $color;
  margin: 0;
  min-height: 100vh;
  box-shadow: inset 0 0 150px rgba($color, .4), inset 0 0 150px rgba($color, .3);
  
  display: flex;
  min-height: 100vh;
  flex-direction: column;
}                                               
@media (prefers-color-scheme: light)
{
    body {
  background-color: $bgColor;
  background-size: 6px 6px;
  background-image: linear-gradient(90deg, transparent, transparent 3px, rgba(213, 213, 213, 0.07) 4px),
    linear-gradient(transparent, transparent 3px, rgba(213, 213, 213, 0.07) 4px);
  color: $color;
  margin: 0;
  min-height: 100vh;
  box-shadow: inset 0 0 150px rgba($color, .4), inset 0 0 150px rgba($color, .3);
  
  display: flex;
  min-height: 100vh;
  flex-direction: column;
}
}.title{
  color:rgb(85, 153, 235);
}
</style>
<nav class="menu-container">
  <!-- burger menu -->
  <input type="checkbox" aria-label="Toggle menu" />
  <span></span>
  <span></span>
  <span></span>

  <!-- logo -->
  <a href="/" class="menu-logo">
    <img style="width: 100%; height: 100%;" src="https://i.imgur.com/2WGRL3v.png" alt=""/>
  </a>

  <!-- menu items -->
  <div class="menubar">
    <ul>
      <li>
        <a href="/stories">
          Stories
        </a>
      </li>
      <li>
        <a href="/series-guide/ths-guide">
          Series Guide
        </a>
      </li>
      <li>
        <a href="/media">
          Media
        </a>
      </li>
      <li>
        <a href="/credits">
          Credits
        </a>
      </li>
            </li>
            <li>
        <a href="https://reader.thehumanserver.org/" target="_blank" rel="noopener noreferrer">
          Reader
        </a>
      </li>
            <li>
        <a href="https://github.com/closesttopurple/THE-HUMAN-SERVER" target="_blank" rel="noopener noreferrer">
          GitHub
        </a>
      </li>
    </ul>
    <ul>
      <li>
        <a href="/bug-report">
          Contact
        </a>
      </li>
    </ul>
  </div>
</nav>
<style>

  @media screen and (orientation: landscape)
{
  .sub-title{
  margin-top: 0.6cm;
  font-size: 150%;
  font-family: "Life-Regular";
  margin-bottom: 0.1cm;
  margin-left: 8%;
  margin-right: 8%;
  font-weight: 500;
letter-spacing: 2.5px;
}
.title{
  font-size: 200%;

}

}
#img-front{
        width: 40%;
    height: 40%;
          border: thick solid rgb(25, 25, 25);
    background-color: rgb(70, 70, 70);
}
  @media screen and (orientation: portrait)
{
  .sub-title{
  margin-top: 1cm;
  font-size: 130%;
  font-family: "Life-Regular";
  font-weight: 400;
  margin-bottom: 0.1cm;
}
.title{
    font-size: 180%;
}

}
.title{
    margin: 0%;
}
.over-text-media{
width: 80%;
height: 60%;
margin: 0 auto;
  text-align: justify;
padding: 1rem;}
 @media  (prefers-color-scheme: dark){

  .text-bg{
  background-color:rgb(70, 70, 70);
  padding: 0.7rem;
}
}
  @media  (prefers-color-scheme: light){

  .text-bg{
  background-color:rgb(253, 253, 253);
  padding: 0.7rem;
}

}
#img-small{
          width: 351px;
    height: 355.75px;
}
#img-small-2{
          width: 564px;
    height: 392px;
}@media screen and (orientation: portrait){
    #img-small{
          width:  80%;
    height: 80%;
}
}
</style>
