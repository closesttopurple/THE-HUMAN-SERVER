<title>Barry Esmail</title>
<style>
  @media screen and (orientation: landscape){
    .parent {
display: grid;
grid-template-columns: repeat(3, 1fr) 0.6fr 1.4fr;
grid-template-rows: 0.2fr 0.8fr repeat(2, 0.3fr);
grid-column-gap: 0px;
grid-row-gap: 0px;
}

.div1 { grid-area: 3 / 1 / 5 / 6; }
.div2 { grid-area: 1 / 1 / 2 / 3; }
.div3 { grid-area: 2 / 1 / 3 / 3; }
.div4 { grid-area: 1 / 4 / 3 / 6; }

  }
  @media screen and (orientation: portrait){
.parent {
display: grid;
grid-template-columns: repeat(2, 1fr);
grid-template-rows: 0.2fr 0.8fr repeat(2, 0.3fr) 0.6fr;
grid-column-gap: 0px;
grid-row-gap: 0px;
}

.div1 { grid-area: 3 / 1 / 5 / 6;}
.div2 { grid-area: 1 / 1 / 2 / 3; margin:3%;}
.div3 { grid-area: 2 / 1 / 3 / 3; margin:3%;}
.div4 { grid-area: 5 / 1 / 6 / 3; margin:3%;}

  }


.title{
    font-size: 2rem;
    
}
</style>
